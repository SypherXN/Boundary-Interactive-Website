---
import { gaMeasurementId } from "../data/site";

/**
 * Exact gtag.js snippet format required by Search Console (Google Analytics verification).
 * Must stay in <head> with literal gtag('config', 'G-...') — no bundled/variable wrappers.
 */
const gtagLoader = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
const gtagInit = `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('js', new Date());
gtag('config', '${gaMeasurementId}', {
  send_page_view: true,
  allow_google_signals: true
});`;
---

<!-- Google tag (gtag.js) -->
<script async src={gtagLoader}></script>
<script is:inline set:html={gtagInit}></script>

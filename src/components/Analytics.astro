---
import { gaMeasurementId } from "../data/site";

/**
 * Google Consent Mode v2 defaults (denied until the user accepts in CookieConsent).
 * gtag.js stays in <head> for Search Console; analytics cookies fire only after consent.
 */
const gtagLoader = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
const gtagInit = `window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
gtag('consent', 'default', {
  ad_storage: 'denied',
  ad_user_data: 'denied',
  ad_personalization: 'denied',
  analytics_storage: 'denied',
  functionality_storage: 'denied',
  personalization_storage: 'denied',
  security_storage: 'granted',
  wait_for_update: 500
});
gtag('js', new Date());
gtag('config', '${gaMeasurementId}', {
  send_page_view: false,
  allow_google_signals: false,
  allow_ad_personalization_signals: false
});`;
---

<!-- Google tag (gtag.js) — Consent Mode v2 -->
<script async src={gtagLoader}></script>
<script is:inline set:html={gtagInit}></script>

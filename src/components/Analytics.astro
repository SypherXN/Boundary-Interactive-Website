---
import { gaMeasurementId as defaultMeasurementId } from "../data/site";

/**
 * Google tag (gtag.js) — always in production HTML so Search Console can verify via Google Analytics.
 * Optional PUBLIC_GA_MEASUREMENT_ID overrides the default from site.ts.
 */
const envId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const measurementId =
  typeof envId === "string" && envId.startsWith("G-") ? envId : defaultMeasurementId;
---

<!-- Google tag (gtag.js) -->
<script async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
<script is:inline define:vars={{ measurementId }}>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());
  gtag("config", measurementId);
</script>

---
/**
 * Google Analytics 4 (gtag.js). Set PUBLIC_GA_MEASUREMENT_ID at build time.
 * Search Console can verify ownership via "Google Analytics" when this tag is live
 * and you use the same Google account with Administrator access on the GA property.
 */
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const enabled = Boolean(measurementId && measurementId.startsWith("G-"));
---

{enabled && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script is:inline define:vars={{ measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", measurementId);
    </script>
  </>
)}

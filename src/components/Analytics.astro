---
/**
 * Google Analytics 4 (free tier). Set PUBLIC_GA_MEASUREMENT_ID in .env to enable.
 * Plausible/Umami are paid or self-hosted alternatives if you prefer privacy-focused analytics.
 */
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const enabled = Boolean(measurementId && measurementId.startsWith("G-"));
---

{enabled && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script is:inline define:vars={{ measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", measurementId);
    </script>
  </>
)}

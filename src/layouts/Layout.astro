---
import Analytics from "../components/Analytics.astro";
import AnalyticsEvents from "../components/AnalyticsEvents.astro";
import JsonLd from "../components/JsonLd.astro";
import { brand, defaultOgImage, links, studio, themeColor } from "../data/site";
import { ogImages, socialOgImage } from "../data/seo";
import "../styles/global.css";
import { absoluteUrl } from "../utils/absoluteUrl";
import { withBase } from "../utils/withBase";

interface Props {
  title: string;
  description?: string;
  /** Path under /public for page-specific social preview. */
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  articlePublishedTime?: Date;
  articleModifiedTime?: Date;
  articleAuthors?: string[];
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = studio.description,
  ogImage = defaultOgImage,
  ogType = "website",
  noindex = false,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthors,
  jsonLd
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = absoluteUrl(ogImage, Astro.site);
const ogMeta =
  Object.values(ogImages).find((entry) => entry.path === ogImage) ?? socialOgImage;
const siteName = studio.name;
const isArticle = ogType === "article";
const rssHref = withBase("/rss.xml");

const navItems = [
  { href: "/", label: "Home" },
  { href: "/game", label: "Game" },
  { href: "/devlog", label: "Devlog" },
  { href: "/about", label: "Studio & Team" },
  { href: "/press", label: "Press" },
  { href: "/contact", label: "Contact" }
] as const;

function isActive(href: string) {
  const target = withBase(href.endsWith("/") ? href : `${href}/`);
  const current = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : `${Astro.url.pathname}/`;
  if (href === "/") {
    const home = withBase("/");
    return current === (home.endsWith("/") ? home : `${home}/`);
  }
  return current.startsWith(target);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <link rel="alternate" type="application/rss+xml" title="Boundary Interactive Devlog" href={rssHref} />
    <Analytics />
    <link rel="icon" type="image/svg+xml" href={withBase(brand.icon.default)} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase(brand.favicon32)} />
    <link rel="apple-touch-icon" href={withBase(brand.appleTouchIcon)} sizes="180x180" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content={String(ogMeta.width)} />
    <meta property="og:image:height" content={String(ogMeta.height)} />
    <meta property="og:image:alt" content={ogMeta.alt} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogMeta.alt} />

    {isArticle && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime.toISOString()} />
    )}
    {isArticle && (articleModifiedTime ?? articlePublishedTime) && (
      <meta
        property="article:modified_time"
        content={(articleModifiedTime ?? articlePublishedTime)!.toISOString()}
      />
    )}
    {isArticle &&
      articleAuthors?.map((author) => <meta property="article:author" content={author} />)}

    <meta name="theme-color" content={themeColor} />
    {jsonLd && <JsonLd schema={jsonLd} />}
  </head>
  <body data-ga-base={import.meta.env.BASE_URL.replace(/\/$/, "")}>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={withBase("/")}>
          <img class="brand-icon" src={withBase(brand.icon.default)} alt="Boundary Interactive logo icon" />
          <span>
            <span class="brand-name">{studio.name}</span>
            <span class="brand-tag">Indie Game Studio</span>
          </span>
        </a>
        <nav aria-label="Main navigation">
          <ul>
            {navItems.map(({ href, label }) => (
              <li>
                <a href={withBase(href)} aria-current={isActive(href) ? "page" : undefined}>
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
    </header>
    <main id="main-content" class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p class="muted">© {new Date().getFullYear()} {studio.legalName}</p>
        <div class="footer-links" aria-label="Studio links">
          <a
            class="footer-icon-link"
            href={`mailto:${studio.contactEmail}`}
            aria-label="Email Boundary Interactive"
            title="Email"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M20 5H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm-.4 2L12 12.4 4.4 7h15.2ZM4 17V9.3l7.4 5.2a1 1 0 0 0 1.2 0L20 9.3V17H4Z"
              />
            </svg>
          </a>
          <a
            class="footer-icon-link"
            href={links.linkedinCompany}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Boundary Interactive on LinkedIn"
            title="LinkedIn"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M6.94 8.5a1.68 1.68 0 1 1 0-3.36 1.68 1.68 0 0 1 0 3.36ZM8.38 19H5.5V9.67h2.88V19ZM19 19h-2.88v-4.8c0-1.14-.02-2.61-1.59-2.61-1.6 0-1.85 1.25-1.85 2.53V19H9.8V9.67h2.76v1.27h.04c.39-.73 1.32-1.5 2.72-1.5 2.9 0 3.44 1.91 3.44 4.39V19Z"
              />
            </svg>
          </a>
          <a
            class="footer-icon-link"
            href={links.youtubeChannel}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Fly Exterminator on YouTube"
            title="YouTube"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M21.58 7.19a2.87 2.87 0 0 0-2.02-2.03C17.78 4.67 12 4.67 12 4.67s-5.78 0-7.56.49A2.87 2.87 0 0 0 2.42 7.2C1.94 8.98 1.94 12 1.94 12s0 3.02.48 4.8a2.87 2.87 0 0 0 2.02 2.03c1.78.49 7.56.49 7.56.49s5.78 0 7.56-.49a2.87 2.87 0 0 0 2.02-2.03c.48-1.78.48-4.8.48-4.8s0-3.02-.48-4.8ZM10.17 14.75V9.25L14.92 12l-4.75 2.75Z"
              />
            </svg>
          </a>
          <a
            class="footer-icon-link"
            href={links.discord}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Fly Exterminator on Discord"
            title="Discord"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03ZM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.419 0 1.334-.956 2.419-2.157 2.419Zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.419 0 1.334-.946 2.419-2.157 2.419Z"
              />
            </svg>
          </a>
        </div>
      </div>
    </footer>
    <AnalyticsEvents />
  </body>
</html>

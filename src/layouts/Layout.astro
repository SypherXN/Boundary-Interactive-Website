---
import Analytics from "../components/Analytics.astro";
import AnalyticsEvents from "../components/AnalyticsEvents.astro";
import JsonLd from "../components/JsonLd.astro";
import { brand, defaultOgImage, links, studio, themeColor } from "../data/site";
import { ogImages, socialOgImage } from "../data/seo";
import "../styles/global.css";
import { absoluteUrl } from "../utils/absoluteUrl";
import { withBase } from "../utils/withBase";

interface Props {
  title: string;
  description?: string;
  /** Path under /public for page-specific social preview. */
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
  articlePublishedTime?: Date;
  articleModifiedTime?: Date;
  articleAuthors?: string[];
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = studio.description,
  ogImage = defaultOgImage,
  ogType = "website",
  noindex = false,
  articlePublishedTime,
  articleModifiedTime,
  articleAuthors,
  jsonLd
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = absoluteUrl(ogImage, Astro.site);
const ogMeta =
  Object.values(ogImages).find((entry) => entry.path === ogImage) ?? socialOgImage;
const siteName = studio.name;
const isArticle = ogType === "article";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Analytics />
    <link rel="icon" type="image/svg+xml" href={withBase(brand.icon.default)} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase(brand.favicon32)} />
    <link rel="apple-touch-icon" href={withBase(brand.appleTouchIcon)} sizes="180x180" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content={String(ogMeta.width)} />
    <meta property="og:image:height" content={String(ogMeta.height)} />
    <meta property="og:image:alt" content={ogMeta.alt} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogMeta.alt} />

    {isArticle && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime.toISOString()} />
    )}
    {isArticle && (articleModifiedTime ?? articlePublishedTime) && (
      <meta
        property="article:modified_time"
        content={(articleModifiedTime ?? articlePublishedTime)!.toISOString()}
      />
    )}
    {isArticle &&
      articleAuthors?.map((author) => <meta property="article:author" content={author} />)}

    <meta name="theme-color" content={themeColor} />
    {jsonLd && <JsonLd schema={jsonLd} />}
  </head>
  <body data-ga-base={import.meta.env.BASE_URL.replace(/\/$/, "")}>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={withBase("/")}>
          <img class="brand-icon" src={withBase(brand.icon.default)} alt="Boundary Interactive logo icon" />
          <span>
            <span class="brand-name">{studio.name}</span>
            <span class="brand-tag">Indie Game Studio</span>
          </span>
        </a>
        <nav aria-label="Main navigation">
          <ul>
            <li><a href={withBase("/")}>Home</a></li>
            <li><a href={withBase("/game")}>Game</a></li>
            <li><a href={withBase("/devlog")}>Devlog</a></li>
            <li><a href={withBase("/about")}>Studio & Team</a></li>
            <li><a href={withBase("/press")}>Press</a></li>
            <li><a href={withBase("/contact")}>Contact</a></li>
          </ul>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <p class="muted">© {new Date().getFullYear()} {studio.legalName}</p>
        <div class="footer-links" aria-label="Studio links">
          <a
            class="footer-icon-link"
            href={`mailto:${studio.contactEmail}`}
            aria-label="Email Boundary Interactive"
            title="Email"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M20 5H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2Zm-.4 2L12 12.4 4.4 7h15.2ZM4 17V9.3l7.4 5.2a1 1 0 0 0 1.2 0L20 9.3V17H4Z"
              />
            </svg>
          </a>
          <a
            class="footer-icon-link"
            href={links.linkedinCompany}
            target="_blank"
            rel="noreferrer"
            aria-label="Boundary Interactive on LinkedIn"
            title="LinkedIn"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M6.94 8.5a1.68 1.68 0 1 1 0-3.36 1.68 1.68 0 0 1 0 3.36ZM8.38 19H5.5V9.67h2.88V19ZM19 19h-2.88v-4.8c0-1.14-.02-2.61-1.59-2.61-1.6 0-1.85 1.25-1.85 2.53V19H9.8V9.67h2.76v1.27h.04c.39-.73 1.32-1.5 2.72-1.5 2.9 0 3.44 1.91 3.44 4.39V19Z"
              />
            </svg>
          </a>
          <a
            class="footer-icon-link"
            href={links.youtubeChannel}
            target="_blank"
            rel="noreferrer"
            aria-label="Fly Exterminator on YouTube"
            title="YouTube"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M21.58 7.19a2.87 2.87 0 0 0-2.02-2.03C17.78 4.67 12 4.67 12 4.67s-5.78 0-7.56.49A2.87 2.87 0 0 0 2.42 7.2C1.94 8.98 1.94 12 1.94 12s0 3.02.48 4.8a2.87 2.87 0 0 0 2.02 2.03c1.78.49 7.56.49 7.56.49s5.78 0 7.56-.49a2.87 2.87 0 0 0 2.02-2.03c.48-1.78.48-4.8.48-4.8s0-3.02-.48-4.8ZM10.17 14.75V9.25L14.92 12l-4.75 2.75Z"
              />
            </svg>
          </a>
          <a
            class="footer-icon-link"
            href={links.discord}
            target="_blank"
            rel="noreferrer"
            aria-label="Fly Exterminator on Discord"
            title="Discord"
          >
            <svg class="footer-icon" viewBox="0 0 24 24" aria-hidden="true">
              <path
                fill="currentColor"
                d="M20.32 4.37a18.9 18.9 0 0 0-4.7-1.46l-.22.4a17.4 17.4 0 0 0-4.2 0l-.22-.4a18.9 18.9 0 0 0-4.7 1.46 16.5 16.5 0 0 0-3.2 8.1 16.8 16.8 0 0 0 5.1 2.6 12.6 12.6 0 0 0 1.1-1.8 8.4 8.4 0 0 1-1.7-.8l.4-.3a12.2 12.2 0 0 0 10.4 0l.4.3a8.4 8.4 0 0 1-1.7.8c.3.7.7 1.3 1.1 1.8a16.8 16.8 0 0 0 5.1-2.6 16.5 16.5 0 0 0-3.2-8.1ZM8.7 14.6a1.9 1.9 0 0 1-1.8-2c0-1 .8-1.9 1.8-1.9s1.9.9 1.8 1.9c0 1.1-.8 2-1.8 2Zm6.6 0a1.9 1.9 0 0 1-1.8-2c0-1 .8-1.9 1.8-1.9s1.9.9 1.8 1.9c0 1.1-.8 2-1.8 2Z"
              />
            </svg>
          </a>
        </div>
      </div>
    </footer>
    <AnalyticsEvents />
  </body>
</html>

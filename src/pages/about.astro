---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { game, studio, teamMembers } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { buildOrganizationSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";

const teamImageByPhoto: Record<string, (typeof images)[keyof typeof images]> = {
  "/matthew-tran.png": images.teamMatthew,
  "/chaeho-shin.png": images.teamChaeho
};
---

<Layout
  title={pageSeo.about.title}
  description={pageSeo.about.description}
  ogImage={ogImages.default.path}
  jsonLd={buildOrganizationSchema(Astro.site)}
>
  <section class="hero">
    <h1>Studio & Team</h1>
    <p>
      {studio.name} is a two-person indie studio focused on mixed-reality game development.
      Our current title is <a href={withBase("/game")}>{game.title}</a> for {game.platform}.
    </p>
  </section>

  <section class="grid">
    {teamMembers.map((member) => {
      const photo = teamImageByPhoto[member.photo] ?? images.teamMatthew;
      return (
        <article class="panel team-card">
          <OptimizedImage
            class={`team-photo ${member.name === "Matthew Tran" ? "team-photo-matthew" : ""}`}
            src={photo.src}
            alt={`${member.name} headshot`}
            width={220}
            height={220}
          />
          <h2>{member.name}</h2>
          <p class="muted">{member.role}</p>
          <p>{member.bio}</p>
          <p>{member.responsibilities}</p>
          <p>
            {member.links.map((link, index) => (
              <>
                {index > 0 && " • "}
                <a href={link.href}>{link.label}</a>
              </>
            ))}
          </p>
        </article>
      );
    })}
  </section>

  <section class="panel">
    <p>
      <a href={withBase("/devlog")}>Fly Exterminator devlog</a>
      •
      <a href={withBase("/press")}>Press kit</a>
    </p>
  </section>
</Layout>

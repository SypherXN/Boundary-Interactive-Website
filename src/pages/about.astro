---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { game, studio, teamMembers } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { buildOrganizationSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";

const teamImageByPhoto: Record<string, (typeof images)[keyof typeof images]> = {
  [images.teamMatthew.src]: images.teamMatthew,
  [images.teamChaeho.src]: images.teamChaeho
};
---

<Layout
  title={pageSeo.about.title}
  description={pageSeo.about.description}
  ogImage={ogImages.default.path}
  jsonLd={buildOrganizationSchema(Astro.site)}
>
  <section class="hero">
    <h1>Studio & Team</h1>
    <p>
      {studio.name} is a two-person indie studio focused on mixed-reality game development for
      {game.platform}. Our current title is <a href={withBase("/game")}>{game.title}</a>.
    </p>
  </section>

  <section class="panel about-studio-panel">
    <h2>About Boundary Interactive</h2>
    <div class="about-studio-copy">
      {studio.about.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
      <p class="muted">{game.releaseTarget}</p>
    </div>
    <figure class="about-expo-figure media-block">
      <OptimizedImage
        class="showcase-image"
        src={images.devlogUscExpo.src}
        alt="Matthew Tran and Chaeho Shin at USC Games Expo 2026 showcasing Fly Exterminator."
        width={images.devlogUscExpo.width}
        height={images.devlogUscExpo.height}
      />
      <figcaption class="about-expo-caption">
        USC Games Expo 2026 — showcasing Fly Exterminator and gathering player feedback.
      </figcaption>
    </figure>
  </section>

  <section class="about-team-grid" aria-label="Team members">
    {teamMembers.map((member) => {
      const photo = teamImageByPhoto[member.photo] ?? images.teamMatthew;
      return (
        <article class="panel team-card">
          <OptimizedImage
            class={`team-photo ${member.name === "Matthew Tran" ? "team-photo-matthew" : ""}`}
            src={photo.src}
            alt={`${member.name} headshot`}
            width={220}
            height={220}
          />
          <h3>{member.name}</h3>
          <p class="muted team-card-role">{member.role}</p>
          <p>{member.bio}</p>
          <p>{member.responsibilities}</p>
          <p class="team-card-links">
            {member.links.map((link, index) => (
              <>
                {index > 0 && " • "}
                <a href={link.href}>{link.label}</a>
              </>
            ))}
          </p>
        </article>
      );
    })}
  </section>

  <section class="panel">
    <p>
      <a href={withBase("/game")}>{game.title} game page</a>
      •
      <a href={withBase("/devlog")}>Devlog</a>
      •
      <a href={withBase("/press")}>Press kit</a>
      •
      <a href={withBase("/contact")}>Contact</a>
    </p>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import { studio, teamMembers } from "../data/site";
---

<Layout title="Boundary Interactive | Contact">
  <section class="hero">
    <h1>Contact</h1>
    <p>
      Reach out for press, business, or collaboration inquiries about Boundary Interactive and
      Fly Exterminator.
    </p>
  </section>

  <section class="panel">
    <h2>Email</h2>
    <p>
      <a href={`mailto:${studio.contactEmail}`}>{studio.contactEmail}</a>
    </p>
    <h2>Official Links</h2>
    <ul>
      {studio.socialLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
    <h2>Team Links</h2>
    <ul>
      {teamMembers.map((member) => (
        <li>
          <strong>{member.name}:</strong>{" "}
          {member.links.map((link, index) => (
            <>
              {index > 0 && " • "}
              <a href={link.href}>{link.label}</a>
            </>
          ))}
        </li>
      ))}
    </ul>
  </section>
</Layout>

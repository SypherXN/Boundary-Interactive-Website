---
import Layout from "../layouts/Layout.astro";
import {
  channelBioLine,
  externalBacklinkChecklist,
  game,
  growthChecklist,
  links,
  siteUrl,
  studio,
  teamMembers
} from "../data/site";
import { ogImages, pageSeo } from "../data/seo";
import { getCollection } from "astro:content";
import { withBase } from "../utils/withBase";

const mappedOfficialLinks = studio.socialLinks.map((link) => ({
  ...link,
  href: link.href.startsWith("/") ? withBase(link.href) : link.href
}));

const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const [latestDevlog] = posts;
const latestDevlogUrl = latestDevlog
  ? new URL(withBase(`/devlog/${latestDevlog.id}/`), Astro.site).href
  : new URL(withBase("/devlog/"), Astro.site).href;

const discordDevlogPost = latestDevlog
  ? `New devlog: **${latestDevlog.data.title}**\n${latestDevlog.data.summary}\n\nRead more: ${latestDevlogUrl}\nWishlist: ${game.storeUrl}\nDiscord: ${links.discord}`
  : `Follow Fly Exterminator development: ${latestDevlogUrl}`;
---

<Layout
  title={pageSeo.contact.title}
  description={pageSeo.contact.description}
  ogImage={ogImages.default.path}
>
  <section class="hero">
    <h1>Contact</h1>
    <p>
      Reach out for press, business, or collaboration inquiries about Boundary Interactive and
      <a href={withBase("/game")}>{game.title}</a>.
    </p>
  </section>

  <section class="panel">
    <h2>Studio Email</h2>
    <p>
      For Boundary Interactive, business, and general studio inquiries:
      <a href={`mailto:${studio.contactEmail}`}>{studio.contactEmail}</a>
    </p>
  </section>

  <section class="panel">
    <h2>{game.title} Email</h2>
    <p>
      For game support, press, and {game.title}-specific questions:
      <a href={`mailto:${game.contactEmail}`}>{game.contactEmail}</a>
    </p>
  </section>

  <section class="panel">
    <h2>Official Links</h2>
    <ul>
      {mappedOfficialLinks.map((link) => (
        <li>
          <a href={link.href}>{link.label}</a>
        </li>
      ))}
      <li><a href={withBase("/devlog")}>Fly Exterminator devlog</a></li>
    </ul>
  </section>

  <section class="panel growth-panel">
    <h2>Grow discovery</h2>
    <p>Quick actions after each deploy — paste these links on your external channels.</p>
    <ul class="growth-actions">
      <li>
        <strong>Official site URL</strong>
        <code class="copy-snippet">{siteUrl}</code>
        <button type="button" class="button secondary copy-btn" data-copy-text={siteUrl}>
          Copy URL
        </button>
      </li>
      <li>
        <strong>Channel bio line</strong>
        <code class="copy-snippet">{channelBioLine}</code>
        <button type="button" class="button secondary copy-btn" data-copy-text={channelBioLine}>
          Copy bio
        </button>
      </li>
      {latestDevlog && (
        <li>
          <strong>Discord devlog announcement</strong>
          <code class="copy-snippet copy-snippet-block">{discordDevlogPost}</code>
          <button type="button" class="button secondary copy-btn" data-copy-text={discordDevlogPost}>
            Copy Discord post
          </button>
        </li>
      )}
    </ul>
    <ul>
      {growthChecklist.map((item) => (
        <li>
          <strong>{item.title}</strong> — {item.detail}
          {" "}
          (<a href={item.href.startsWith("http") ? item.href : withBase(item.href)}>open</a>)
        </li>
      ))}
    </ul>
  </section>

  <section class="panel">
    <h2>Link this site from your channels</h2>
    <p>
      Paste our official website URL into external profiles so players and press can find the
      <a href={withBase("/game")}>Fly Exterminator game page</a>, devlog, and press kit.
    </p>
    <ul class="backlink-list">
      {externalBacklinkChecklist.map((item) => (
        <li class="backlink-item">
          <p>
            <strong>{item.channel}</strong> — {item.field}
            (<a href={item.profileUrl}>open profile</a>)
          </p>
          <code class="copy-snippet">{item.pasteValue}</code>
          <button
            type="button"
            class="button secondary copy-btn"
            data-copy-text={item.pasteValue}
          >
            Copy for {item.channel}
          </button>
        </li>
      ))}
    </ul>
  </section>

  <section class="panel">
    <h2>Team Contacts</h2>
    {teamMembers.map((member) => (
      <div class="team-contact">
        <h3>{member.name}</h3>
        <p>
          {member.links.map((link, index) => (
            <>
              {index > 0 && " • "}
              <a href={link.href}>{link.label}</a>
            </>
          ))}
        </p>
      </div>
    ))}
  </section>
</Layout>

<script>
  import "../scripts/copy-helpers.ts";
</script>

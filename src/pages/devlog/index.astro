---
import Layout from "../../layouts/Layout.astro";
import { game, links } from "../../data/site";
import { getCollection } from "astro:content";
import { ogImages, pageSeo } from "../../data/seo";
import { formatDateUTC } from "../../utils/date";
import { withBase } from "../../utils/withBase";

const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout
  title={pageSeo.devlogIndex.title}
  description={pageSeo.devlogIndex.description}
  ogImage={ogImages.default.path}
>
  <section class="hero">
    <h1>Devlog</h1>
    <p>
      Development updates for <a href={withBase("/game")}>{game.title}</a> on {game.platform} as
      Boundary Interactive moves from early mixed-reality prototypes through USC Games Expo 2026 and
      toward {game.releaseTarget.toLowerCase()}. Press and media can use the
      <a href={withBase("/press")}>Fly Exterminator press kit</a>. Subscribe via
      <a href={withBase("/rss.xml")}>RSS</a>.
    </p>
  </section>

  <section class="grid">
    {posts.map((post) => (
      <article class="panel">
        <p class="muted">{formatDateUTC(post.data.date)}</p>
        <h2>
          <a href={withBase(`/devlog/${post.id}/`)}>{post.data.title}</a>
        </h2>
        <p>{post.data.summary}</p>
      </article>
    ))}
  </section>

  <section class="panel">
    <p>
      <a href={withBase("/game")}>Fly Exterminator game page</a>
      •
      <a href={game.storeUrl}>Meta Store listing</a>
      •
      <a href={links.discord}>Discord community</a>
    </p>
  </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { game, links } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { getCollection } from "astro:content";
import { buildVideoGameSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";

const [gameEntry] = await getCollection("games");
const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const [latestDevlog] = posts;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
---

<Layout
  title={pageSeo.game.title}
  description={pageSeo.game.description}
  ogImage={ogImages.game.path}
  jsonLd={buildVideoGameSchema(Astro.site, canonicalURL)}
>
  <section class="hero">
    <p class="status">{game.status} • {game.releaseWindow}</p>
    <h1>{game.title}</h1>
    <p>{game.pitch}</p>
    <p class="muted">Genres: {game.genres.join(" / ")} • Rating: {game.rating}</p>
    <figure class="media-block">
      <OptimizedImage
        class="showcase-image"
        src={images.heroArt.src}
        alt="Fly Exterminator key art showing player swatting a fly in a living room."
        width={images.heroArt.width}
        height={images.heroArt.height}
        loading="eager"
      />
    </figure>
    <div class="btn-row">
      <a class="button" href={game.storeUrl}>Wishlist on Meta</a>
      <a class="button secondary" href={withBase("/press")}>Fly Exterminator press kit</a>
    </div>
  </section>

  <section class="panel">
    <h2>Official Trailer</h2>
    <figure class="media-block">
      <div class="video-embed">
        <iframe
          src={game.trailerEmbedUrl}
          title="Fly Exterminator Official Trailer"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <figcaption class="media-caption">
        Trailer footage from the latest polish pass leading into expo and Early Access prep.
      </figcaption>
    </figure>
  </section>

  <section class="panel">
    <h2>Feature Highlights</h2>
    <ul>
      <li>Room-scale mixed reality with Quest scene capture.</li>
      <li>Quick-reflex gameplay designed for short sessions.</li>
      <li>Satisfying fly-catching interactions integrated into your real environment.</li>
      <li>Time-trial style score chasing and replayability.</li>
    </ul>
    <figure class="media-block">
      <OptimizedImage
        src={images.roomScanning.src}
        alt="Meta Quest 3 room scanning overlay used for Fly Exterminator mixed-reality development."
        class="showcase-image"
        width={images.roomScanning.width}
        height={images.roomScanning.height}
      />
      <figcaption class="media-caption">
        Room-scanning tests that helped anchor fly behavior to real-world surfaces.
      </figcaption>
    </figure>
    <figure class="media-block">
      <OptimizedImage
        src={images.gameUi.src}
        alt="Fly Exterminator in-game mixed-reality menu UI showing time trial options and scoring instructions."
        class="showcase-image"
        width={images.gameUi.width}
        height={images.gameUi.height}
      />
      <figcaption class="media-caption">
        Newest in-game UI tuned for quick setup, readability, and competitive score chasing.
      </figcaption>
    </figure>
  </section>

  <section class="panel">
    <h2>Player FAQ</h2>
    <p><strong>Platform:</strong> {game.platform}</p>
    <p><strong>Release status:</strong> {game.status} (target window {game.releaseWindow}).</p>
    <p>
      <strong>Who is making it?</strong>
      <a href={withBase("/about")}>Boundary Interactive</a>, founded by Matthew Tran and Chaeho Shin.
    </p>
    <p>
      <strong>Where can I follow updates?</strong>
      Use the <a href={game.storeUrl}>Meta store listing</a>,
      <a href={links.discord}>Discord community</a>,
      <a href={withBase("/devlog")}>devlog</a>,
      <a href={withBase("/press")}>press kit</a>, or email
      <a href={`mailto:${game.contactEmail}`}>{game.contactEmail}</a>.
    </p>
  </section>

  {latestDevlog && (
    <section class="panel">
      <h2>Latest Devlog</h2>
      <p>
        <a href={withBase(`/devlog/${latestDevlog.id}/`)}>{latestDevlog.data.title}</a>
        — {latestDevlog.data.summary}
      </p>
      <p><a href={withBase("/devlog")}>View all Fly Exterminator devlog posts</a></p>
    </section>
  )}

  {gameEntry && (
    <section class="panel">
      <h2>Development Timeline</h2>
      <p>{gameEntry.data.timeline}</p>
    </section>
  )}
</Layout>

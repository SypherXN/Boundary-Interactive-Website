---
import Layout from "../layouts/Layout.astro";
import { game } from "../data/site";
import { getCollection } from "astro:content";
import { withBase } from "../utils/withBase";

const [gameEntry] = await getCollection("games");
---

<Layout title="Fly Exterminator | Game" description={game.pitch}>
  <section class="hero">
    <p class="status">{game.status} • {game.releaseWindow}</p>
    <h1>{game.title}</h1>
    <p>{game.pitch}</p>
    <p class="muted">Genres: {game.genres.join(" / ")} • Rating: {game.rating}</p>
    <figure class="media-block">
      <img
        class="showcase-image"
        src={withBase("/fly-exterminator-hero-art.png")}
        alt="Fly Exterminator key art showing player swatting a fly in a living room."
      />
    </figure>
    <div class="btn-row">
      <a class="button" href={game.storeUrl}>Wishlist on Meta</a>
      <a class="button secondary" href={withBase("/press")}>Press info</a>
    </div>
  </section>

  <section class="panel">
    <h2>Official Trailer</h2>
    <figure class="media-block">
      <div class="video-embed">
        <iframe
          src="https://www.youtube.com/embed/pCl-uN2TTYY"
          title="Fly Exterminator Official Trailer"
          loading="lazy"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <figcaption class="media-caption">
        Trailer footage from the latest polish pass leading into expo and Early Access prep.
      </figcaption>
    </figure>
  </section>

  <section class="panel">
    <h2>Feature Highlights</h2>
    <ul>
      <li>Room-scale mixed reality with Quest scene capture.</li>
      <li>Quick-reflex gameplay designed for short sessions.</li>
      <li>Satisfying fly-catching interactions integrated into your real environment.</li>
      <li>Time-trial style score chasing and replayability.</li>
    </ul>
    <figure class="media-block">
      <img
        src={withBase("/meta-quest-room-scanning.png")}
        alt="Meta Quest 3 room scanning overlay used for Fly Exterminator mixed-reality development."
        class="showcase-image"
      />
      <figcaption class="media-caption">
        Room-scanning tests that helped anchor fly behavior to real-world surfaces.
      </figcaption>
    </figure>
    <figure class="media-block">
      <img
        src={withBase("/fly-exterminator-ui.png")}
        alt="Fly Exterminator in-game mixed-reality menu UI showing time trial options and scoring instructions."
        class="showcase-image"
      />
      <figcaption class="media-caption">
        Newest in-game UI tuned for quick setup, readability, and competitive score chasing.
      </figcaption>
    </figure>
  </section>

  <section class="panel">
    <h2>Player FAQ</h2>
    <p><strong>Platform:</strong> Meta Quest 3</p>
    <p><strong>Release status:</strong> Coming soon (target window June 2026).</p>
    <p><strong>Who is making it?</strong> Boundary Interactive, founded by Matthew Tran and Chaeho Shin.</p>
    <p><strong>Where can I follow updates?</strong> Use the Meta store listing and press kit linked below.</p>
  </section>

  {gameEntry && (
    <section class="panel">
      <h2>Development Timeline</h2>
      <p>{gameEntry.data.timeline}</p>
    </section>
  )}
</Layout>

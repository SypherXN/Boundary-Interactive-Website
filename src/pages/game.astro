---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { game, links } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { getCollection } from "astro:content";
import { buildVideoGameSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";

const [gameEntry] = await getCollection("games");
const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const [latestDevlog] = posts;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
---

<Layout
  title={pageSeo.game.title}
  description={pageSeo.game.description}
  ogImage={ogImages.game.path}
  jsonLd={buildVideoGameSchema(Astro.site, canonicalURL)}
>
  <section class="hero">
    <p class="status">{game.status} • {game.releaseWindow} • {game.platform}</p>
    <p class="muted release-target">{game.releaseTarget}</p>
    <h1>{game.title}</h1>
    <p>{game.pitch}</p>
    <p class="muted">{game.shortDescription}</p>
    <p class="muted">Genres: {game.genres.join(" / ")} • Rating: {game.rating}</p>
    <figure class="media-block">
      <div class="video-embed">
        <iframe
          src={game.trailerEmbedUrl}
          title="Fly Exterminator Official Trailer"
          loading="eager"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <figcaption class="media-caption">
        Official trailer — mixed-reality fly catching on Meta Quest 3, ahead of Early Access.
      </figcaption>
    </figure>
    <div class="btn-row">
      <a class="button" href={game.storeUrl}>Wishlist on Meta Store</a>
      <a class="button secondary" href={withBase("/press")}>Fly Exterminator press kit</a>
    </div>
  </section>

  <section class="panel">
    <h2>About the game</h2>
    {game.about.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </section>

  <section class="panel">
    <h2>How it plays</h2>
    <ol class="game-steps">
      {game.howItPlays.map((step) => (
        <li>{step}</li>
      ))}
    </ol>
  </section>

  <section class="panel">
    <h2>Feature highlights</h2>
    <ul>
      {game.highlights.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <figure class="media-block">
      <OptimizedImage
        class="showcase-image"
        src={images.heroArt.src}
        alt="Fly Exterminator key art showing a player swatting a fly in a living room."
        width={images.heroArt.width}
        height={images.heroArt.height}
      />
      <figcaption class="media-caption">
        Key art — hand-tracked swatting in a real living room playspace.
      </figcaption>
    </figure>
    <figure class="media-block">
      <OptimizedImage
        src={images.roomScanning.src}
        alt="Meta Quest 3 room scanning overlay used for Fly Exterminator mixed-reality development."
        class="showcase-image"
        width={images.roomScanning.width}
        height={images.roomScanning.height}
      />
      <figcaption class="media-caption">
        Room-scanning and hand-tracking tests that anchor fly paths and catches to your real environment.
      </figcaption>
    </figure>
    <figure class="media-block">
      <OptimizedImage
        src={images.gameUi.src}
        alt="Fly Exterminator in-game mixed-reality menu UI showing time trial options and scoring instructions."
        class="showcase-image"
        width={images.gameUi.width}
        height={images.gameUi.height}
      />
      <figcaption class="media-caption">
        Mixed-reality UI for mode setup and score chasing—designed for clarity during playtests and expo demos.
      </figcaption>
    </figure>
  </section>

  <section class="panel">
    <h2>Player FAQ</h2>
    <p><strong>Platform:</strong> {game.platform} (mixed reality; room setup and scene capture required).</p>
    <p>
      <strong>Release:</strong> {game.status} — {game.releaseTarget}.
    </p>
    <p>
      <strong>Controls:</strong> Hand tracking for swatting flies; in-headset UI for menus and mode setup.
    </p>
    <p>
      <strong>Modes:</strong> Built around arcade score chasing—including Time Attack runs used for expo demos,
      plus additional modes and tutorials developed through alpha and beta milestones.
    </p>
    <p>
      <strong>Who is making it?</strong>
      <a href={withBase("/about")}>Boundary Interactive</a>, a two-person studio founded by Matthew Tran and
      Chaeho Shin. The team showcased the game at USC Games Expo 2026 and is polishing toward launch.
    </p>
    <p>
      <strong>Where can I follow updates?</strong>
      Wishlist on the <a href={game.storeUrl}>Meta Store listing</a>, join the
      <a href={links.discord}>Discord community</a>, read the <a href={withBase("/devlog")}>devlog</a>, browse the
      <a href={withBase("/press")}>press kit</a>, or email
      <a href={`mailto:${game.contactEmail}`}>{game.contactEmail}</a>.
    </p>
  </section>

  {latestDevlog && (
    <section class="panel">
      <h2>Latest devlog</h2>
      <p>
        <a href={withBase(`/devlog/${latestDevlog.id}/`)}>{latestDevlog.data.title}</a>
        — {latestDevlog.data.summary}
      </p>
      <p><a href={withBase("/devlog")}>View all Fly Exterminator devlog posts</a></p>
    </section>
  )}

  {gameEntry && (
    <section class="panel">
      <h2>Development timeline</h2>
      <p>{gameEntry.data.timeline}</p>
    </section>
  )}
</Layout>

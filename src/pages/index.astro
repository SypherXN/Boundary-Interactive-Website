---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { brand, game, links, studio } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { buildOrganizationSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";
import { getCollection } from "astro:content";

const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const [latestDevlog] = posts;
---

<Layout
  title={pageSeo.home.title}
  description={pageSeo.home.description}
  ogImage={ogImages.default.path}
  jsonLd={buildOrganizationSchema(Astro.site)}
>
  <section class="home-logo-stage">
    <img
      class="studio-wordmark"
      src={withBase(brand.wordmark.default)}
      alt="Boundary Interactive full logo."
      width="760"
      height="266"
      fetchpriority="high"
    />
  </section>

  <section class="hero">
    <h1>{studio.name}</h1>
    <p>{studio.description}</p>
    <h2 class="featured-game-title">{game.title}</h2>
    <p class="status">{game.status} • {game.releaseWindow} • {game.platform}</p>
    <p class="muted release-target">{game.releaseTarget}</p>
    <p>{game.pitch}</p>
    <figure class="media-block">
      <OptimizedImage
        class="showcase-image"
        src={images.coverWide.src}
        alt="Fly Exterminator wide hero cover art."
        width={images.coverWide.width}
        height={images.coverWide.height}
        loading="eager"
      />
    </figure>
    <div class="btn-row">
      <a class="button" href={game.storeUrl}>Wishlist Fly Exterminator on Meta Store</a>
      <a class="button secondary" href={withBase("/game")}>Watch the trailer and learn more</a>
    </div>
  </section>

  <section class="grid">
    <article class="panel">
      <h2>Studio</h2>
      <p>
        We are a two-person team building mixed-reality games where your physical room is the level.
        Learn more on the <a href={withBase("/about")}>Studio &amp; Team</a> page.
      </p>
    </article>
    <article class="panel">
      <h2>Latest development</h2>
      {latestDevlog ? (
        <>
          <p>
            <a href={withBase(`/devlog/${latestDevlog.id}/`)}>{latestDevlog.data.title}</a>
            — {latestDevlog.data.summary}
          </p>
          <p>
            <a href={withBase("/devlog")}>Read all devlog posts</a>
          </p>
        </>
      ) : (
        <p>
          Follow {game.title} from prototyping through Early Access on the
          <a href={withBase("/devlog")}>devlog</a>.
        </p>
      )}
    </article>
    <article class="panel">
      <h2>Follow development</h2>
      <p>
        Wishlist on the <a href={game.storeUrl}>Meta Store listing</a>, join the
        <a href={links.discord}>Fly Exterminator Discord</a>, or browse the
        <a href={withBase("/press")}>press kit</a>.
      </p>
      <div class="btn-row">
        <a class="button secondary" href={game.storeUrl}>Meta Store</a>
        <a class="button secondary" href={links.discord}>Discord</a>
        <a class="button secondary" href={withBase("/press")}>Press kit</a>
      </div>
    </article>
  </section>
</Layout>

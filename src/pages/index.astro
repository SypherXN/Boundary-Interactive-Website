---
import Layout from "../layouts/Layout.astro";
import { brand, game, links, siteUrl, studio } from "../data/site";
import { ogImages, pageSeo } from "../data/seo";
import { buildOrganizationSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";
import { truncateSummary } from "../utils/text";
import { getCollection } from "astro:content";

const posts = (await getCollection("devlogs")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const [latestDevlog] = posts;
---

<Layout
  title={pageSeo.home.title}
  description={pageSeo.home.description}
  ogImage={ogImages.default.path}
  jsonLd={buildOrganizationSchema(Astro.site)}
>
  <section class="home-logo-stage">
    <h1 class="sr-only">{studio.name}</h1>
    <img
      class="studio-wordmark"
      src={withBase(brand.wordmark.default)}
      alt=""
      width="760"
      height="266"
      fetchpriority="high"
      aria-hidden="true"
    />
  </section>

  <section class="hero">
    <p class="status">{game.statusBadge} • {game.platform}</p>
    <p class="muted release-target">{game.releaseTarget}</p>
    <h2 class="featured-game-title">{game.title}</h2>
    <p>{game.pitch}</p>
    <figure class="media-block">
      <div class="video-embed">
        <iframe
          src={game.trailerEmbedUrl}
          title="Fly Exterminator Official Trailer"
          loading="eager"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
      </div>
      <figcaption class="media-caption">
        Official trailer — mixed-reality fly catching on Meta Quest 3.
      </figcaption>
    </figure>
    <div class="btn-row">
      <a class="button" href={links.discord}>Join Fly Exterminator Discord</a>
      <a class="button secondary" href={game.storeUrl}>Wishlist on Meta Store</a>
      <a class="button secondary" href={withBase("/game")}>Full game page</a>
    </div>
  </section>

  <section class="grid">
    <article class="panel">
      <h2>Studio</h2>
      <p>
        We are a two-person team building mixed-reality games where your physical room is the level.
        Learn more on the <a href={withBase("/about")}>Studio &amp; Team</a> page.
      </p>
    </article>
    <article class="panel">
      <h2>Latest development</h2>
      {latestDevlog ? (
        <>
          <p>
            <a href={withBase(`/devlog/${latestDevlog.id}/`)}>{latestDevlog.data.title}</a>
            — {truncateSummary(latestDevlog.data.summary)}
          </p>
          <p>
            <a href={withBase(`/devlog/${latestDevlog.id}/`)}>Read more</a>
            ·
            <a href={withBase("/devlog")}>All devlog posts</a>
          </p>
        </>
      ) : (
        <p>
          Follow {game.title} from prototyping through Early Access on the
          <a href={withBase("/devlog")}>devlog</a>.
        </p>
      )}
    </article>
    <article class="panel">
      <h2>Follow development</h2>
      <p>
        Wishlist on the <a href={game.storeUrl}>Meta Store listing</a>, join the
        <a href={links.discord}>Fly Exterminator Discord</a>, and share our
        <a href={siteUrl}>official website</a> or browse the
        <a href={withBase("/press")}>press kit</a>.
      </p>
      <div class="btn-row">
        <a class="button" href={links.discord}>Join Discord</a>
        <a class="button secondary" href={game.storeUrl}>Meta Store</a>
        <a class="button secondary" href={withBase("/press")}>Press kit</a>
      </div>
    </article>
  </section>
</Layout>

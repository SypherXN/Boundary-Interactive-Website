---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { brand, game, links, studio } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { buildOrganizationSchema } from "../utils/jsonLd";
import { withBase } from "../utils/withBase";
---

<Layout
  title={pageSeo.home.title}
  description={pageSeo.home.description}
  ogImage={ogImages.default.path}
  jsonLd={buildOrganizationSchema(Astro.site)}
>
  <section class="home-logo-stage">
    <img class="studio-wordmark" src={withBase(brand.wordmark.default)} alt="Boundary Interactive full logo." />
  </section>

  <section class="hero">
    <p class="status">{game.status} • {game.releaseWindow} • {game.platform}</p>
    <h1>{game.title}</h1>
    <p>{game.pitch}</p>
    <figure class="media-block">
      <OptimizedImage
        class="showcase-image"
        src={images.coverWide.src}
        alt="Fly Exterminator wide hero cover art."
        width={images.coverWide.width}
        height={images.coverWide.height}
      />
    </figure>
    <div class="btn-row">
      <a class="button" href={game.storeUrl}>Wishlist Fly Exterminator on Meta</a>
      <a class="button secondary" href={withBase("/game")}>Explore the Fly Exterminator game page</a>
    </div>
  </section>

  <section class="grid">
    <article class="panel">
      <h2>Studio</h2>
      <p>{studio.description}</p>
      <p>
        <a href={withBase("/about")}>Meet the Boundary Interactive team</a>.
      </p>
    </article>
    <article class="panel">
      <h2>Latest Development</h2>
      <p>
        {game.title} is being prepared for release with mixed-reality gameplay tuned for short,
        replayable sessions.
      </p>
      <p>
        <a href={withBase("/devlog")}>Read the Fly Exterminator devlog</a> for milestone updates.
      </p>
    </article>
    <article class="panel">
      <h2>Follow Development</h2>
      <p>
        Track launch status on the
        <a href={game.storeUrl}>Meta Quest store listing</a>,
        join the <a href={links.discord}>Fly Exterminator Discord</a>, or browse the
        <a href={withBase("/press")}>press kit</a>.
      </p>
      <div class="btn-row">
        <a class="button secondary" href={game.storeUrl}>Meta store page</a>
        <a class="button secondary" href={links.discord}>Discord community</a>
        <a class="button secondary" href={withBase("/press")}>Press kit</a>
      </div>
    </article>
  </section>
</Layout>

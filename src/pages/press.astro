---
import Layout from "../layouts/Layout.astro";
import OptimizedImage from "../components/OptimizedImage.astro";
import { game, links, pressCredits, pressKitAssets, studio } from "../data/site";
import { images } from "../data/images";
import { ogImages, pageSeo } from "../data/seo";
import { withBase } from "../utils/withBase";

function pressAssetHref(href: string) {
  return href.startsWith("/") ? withBase(href) : href;
}
---

<Layout
  title={pageSeo.press.title}
  description={pageSeo.press.description}
  ogImage={ogImages.press.path}
>
  <section class="hero">
    <h1>Press Kit</h1>
    <p>
      <strong>{game.title}</strong> is a mixed-reality arcade game from <strong>{studio.legalName}</strong>.
      {game.statusBadge} for {game.platform}. {game.releaseTarget}. Visit the
      <a href={withBase("/game")}>official game page</a> for the trailer, screenshots, and FAQ.
    </p>
    <figure class="media-block">
      <OptimizedImage
        class="showcase-image"
        src={images.coverWide.src}
        alt="Fly Exterminator wide hero cover art for press usage."
        width={images.coverWide.width}
        height={images.coverWide.height}
      />
    </figure>
  </section>

  <section class="panel">
    <h2>Factsheet</h2>
    <dl class="factsheet">
      <dt>Game</dt>
      <dd>{game.title}</dd>
      <dt>Developer</dt>
      <dd>{studio.legalName}</dd>
      <dt>Platform</dt>
      <dd>{game.platform}</dd>
      <dt>Genres</dt>
      <dd>{game.genres.join(", ")}</dd>
      <dt>Rating</dt>
      <dd>{game.rating}</dd>
      <dt>Status</dt>
      <dd>{game.status}</dd>
      <dt>Release</dt>
      <dd>{game.releaseTarget}</dd>
      <dt>Store</dt>
      <dd><a href={game.storeUrl}>Meta Store listing</a></dd>
      <dt>Trailer (watch)</dt>
      <dd><a href={links.youtubeTrailer}>YouTube</a></dd>
      <dt>Trailer (embed)</dt>
      <dd>
        <code class="press-embed-url">{game.trailerEmbedUrl}</code>
      </dd>
    </dl>
  </section>

  <section class="panel">
    <h2>One-line pitch</h2>
    <p>{game.pitch}</p>
    <h2>Short description</h2>
    <p>{game.shortDescription}</p>
    <h2>Key features</h2>
    <ul>
      {game.highlights.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <h2>Official links</h2>
    <ul>
      <li><a href={game.storeUrl}>Meta Store listing</a></li>
      <li><a href={links.youtubeChannel}>YouTube channel</a></li>
      <li><a href={links.youtubeTrailer}>Official trailer</a></li>
      <li><a href={links.discord}>Fly Exterminator Discord</a></li>
      <li><a href={links.linkedinCompany}>Boundary Interactive LinkedIn</a></li>
      <li><a href={withBase("/game")}>Official game page</a></li>
      <li><a href={withBase("/devlog")}>Fly Exterminator devlog</a></li>
      <li><a href={withBase("/about")}>Studio &amp; Team</a></li>
    </ul>
  </section>

  <section class="panel">
    <h2>Press assets</h2>
    <ul>
      {pressKitAssets.map((asset) => (
        <li>
          <a href={pressAssetHref(asset.href)}>{asset.label}</a> ({asset.type})
        </li>
      ))}
    </ul>
    <p class="muted credits">{pressCredits}</p>
  </section>

  <section class="panel">
    <h2>Press contact</h2>
    <p>
      <strong>{game.title}</strong> (press, support, game inquiries):
      <a href={`mailto:${game.contactEmail}`}>{game.contactEmail}</a>
    </p>
    <p>
      <strong>{studio.name}</strong> (studio, business, partnerships):
      <a href={`mailto:${studio.contactEmail}`}>{studio.contactEmail}</a>
    </p>
    <p class="muted">
      Full contact options on the
      <a href={withBase("/contact")}>Boundary Interactive contact page</a>.
    </p>
    <div class="btn-row">
      <a class="button secondary" href={withBase("/contact")}>Open contact page</a>
    </div>
  </section>
</Layout>
